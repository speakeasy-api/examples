{
  "name": "users-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node ./dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "npm run lint . --fix",
    "create:openapi": "npx tsx ./src/generateOpenApiDocument.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.9.45",
    "dotenv": "^17.3.0",
    "hono": "^4.12.0",
    "hono-openapi": "^1.2.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "eslint-plugin-format": "^1.0.1",
    "tsx": "^4.19.4"
  }
}

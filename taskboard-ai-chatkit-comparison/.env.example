# Database (SQLite, auto-created)
DATABASE_URL=file:./data/taskmaster.db

# OpenAI API Key (used by other demos; optional if only using Copilot Cloud)
OPENAI_API_KEY=sk-...

# Copilot Cloud (required for CopilotKit demo when using Cloud)
# Get public API key and agent name from https://cloud.copilotkit.ai
NEXT_PUBLIC_COPILOT_CLOUD_PUBLIC_API_KEY=ck_pub_...
NEXT_PUBLIC_COPILOT_AGENT=default

# ChatKit (optional - requires Agent Builder workflow)
# NEXT_PUBLIC_CHATKIT_WORKFLOW_ID=wf_...

# Gram Elements (optional - requires getgram.ai project)
# GRAM_API_KEY=...
# NEXT_PUBLIC_GRAM_PROJECT_SLUG=...
# NEXT_PUBLIC_GRAM_MCP_URL=https://app.getgram.ai/mcp/...
